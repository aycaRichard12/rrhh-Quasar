@baseUrl = https://vivasoft.link/app/prodv1/api
@id_empresa = c0c7c76d30bd3dcaefc96f40275bdc0a

### =========================================================================
### 1. Módulo: Unidad de Medida (Configuración)
### =========================================================================

### 1.1 Listar Unidades de Medida
GET {{baseUrl}}/listaUnidadMedidacoloc/{{id_empresa}}

### 1.2 Cambiar Estado de Unidad
@id_unidad_medida = 1
@estado_unidad_medida = 0
GET {{baseUrl}}/estadoUnidadMedidacoloc/{{id_unidad_medida}}/{{estado_unidad_medida}}

### 1.3 Eliminar Unidad
GET {{baseUrl}}/eliminarUnidadMedidacoloc/{{id_unidad_medida}}

### 1.4 Registrar/Editar Unidad
POST {{baseUrl}}/
Content-Type: multipart/form-data; boundary=MiBoundary123

--MiBoundary123
Content-Disposition: form-data; name="ver"

registroUnidadMedidacoloc
--MiBoundary123
Content-Disposition: form-data; name="empresa"

{{id_empresa}}
--MiBoundary123
Content-Disposition: form-data; name="nombre"

Kilos
--MiBoundary123
Content-Disposition: form-data; name="descripcion"

Unidad de peso
--MiBoundary123--

### =========================================================================
### 2. Módulo: Unidad de Tiempo (Configuración)
### =========================================================================

### 2.1 Listar Unidades de Tiempo
GET {{baseUrl}}/listaUnidadTiempoControl/{{id_empresa}}

### 2.2 Eliminar Unidad
@id_unidad_tiempo = 1
GET {{baseUrl}}/eliminarUnidadTiempoControl/{{id_unidad_tiempo}}

### 2.3 Registrar Unidad de Tiempo
POST {{baseUrl}}/
Content-Type: multipart/form-data; boundary=MiBoundary123

--MiBoundary123
Content-Disposition: form-data; name="ver"

registrar_unidad_tiempo
--MiBoundary123
Content-Disposition: form-data; name="empresa"

{{id_empresa}}
--MiBoundary123
Content-Disposition: form-data; name="nombre"

Minutos
--MiBoundary123--

